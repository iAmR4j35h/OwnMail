# ===========================================
# Resend Email Gateway — Environment Config
# ===========================================

# Resend API key (required)
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your verified domain in Resend
DOMAIN=example.com

# Webhook secret for verifying inbound email signatures
# Found in Resend dashboard under Webhooks
WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API key for authenticating requests to the gateway
# Generate a strong random string (e.g. openssl rand -hex 32)
API_KEY=your-secret-api-key-here

# Storage adapter: "sqlite" (default) or "postgres"
STORAGE_ADAPTER=sqlite

# SQLite database path (only used when STORAGE_ADAPTER=sqlite)
SQLITE_PATH=./data/emails.db

# PostgreSQL connection string (only used when STORAGE_ADAPTER=postgres)
# DATABASE_URL=postgresql://user:password@localhost:5432/resend_gateway

# Server port
SERVER_PORT=8080

# Dashboard port
DASHBOARD_PORT=3000

# Internal API URL (used by dashboard to reach server in Docker)
INTERNAL_API_URL=http://localhost:8080

# Log level: "debug" | "info" | "warn" | "error"
LOG_LEVEL=info
